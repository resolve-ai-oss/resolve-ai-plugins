#!/usr/bin/env node
// Investigation subscriber: pipes an agent-teams investigation's trace stream
// (theory cards, evidence trail, phase) to stdout, and refreshes a structured
// get_investigation snapshot into <state-dir>/state.json over the run. The
// server owns the wire format and termination; this just follows the stream.
//
// Usage: resolve-watch-investigation <investigation_id> --watch-token <token>
// The watch token (from start_investigation / steer_investigation) is sent as
// ?watch_token=; the base URL comes from config.json.

import fs from "node:fs/promises"
import fsSync from "node:fs"
import path from "node:path"
import os from "node:os"
import { fileURLToPath } from "node:url"

const PLUGIN_ROOT = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..")
const CONFIG_PATH = path.join(PLUGIN_ROOT, "config.json")

// Cadence for refreshing the state.json snapshot while the stream is live.
const SNAPSHOT_INTERVAL_MS = 20_000

function usage() {
  process.stderr.write("Usage: resolve-watch-investigation <investigation_id> --watch-token <token>\n")
  process.stderr.write("The watch token is returned by start_investigation / steer_investigation (no API key).\n")
  process.exit(2)
}

function parseArgs(argv) {
  const args = argv.slice(2)
  if (args.length === 0) usage()
  const investigationId = args[0]
  if (!investigationId || investigationId.startsWith("--")) usage()
  let watchToken
  for (let i = 1; i < args.length; i++) {
    const flag = args[i]
    if (flag === "--watch-token") {
      const v = args[++i]
      if (!v) usage()
      watchToken = v
    } else {
      usage()
    }
  }
  if (!watchToken) usage()
  return { investigationId, watchToken }
}

function resolveBaseUrl() {
  const raw = fsSync.readFileSync(CONFIG_PATH, "utf8")
  const json = JSON.parse(raw)
  if (typeof json.baseUrl !== "string") {
    throw new Error(`resolve-watch-investigation: ${CONFIG_PATH} is missing a string "baseUrl" field`)
  }
  return json.baseUrl.replace(/\/+$/, "")
}

let writeSeq = 0
async function writeStateAtomic(stateDir, state) {
  await fs.mkdir(stateDir, { recursive: true })
  // Unique tmp name per write so concurrent snapshots can't collide; rename is atomic.
  const tmpPath = path.join(stateDir, `state.json.${process.pid}.${++writeSeq}.tmp`)
  const finalPath = path.join(stateDir, "state.json")
  await fs.writeFile(tmpPath, JSON.stringify(state, null, 2))
  await fs.rename(tmpPath, finalPath)
}

async function fetchGetInvestigation(baseUrl, investigationId, watchToken) {
  const params = new URLSearchParams()
  params.set("watch_token", watchToken)
  const url = `${baseUrl}/api/resolve-mcp/v2/investigations/${encodeURIComponent(investigationId)}?${params.toString()}`
  const resp = await fetch(url)
  if (!resp.ok) {
    const body = await resp.text().catch(() => "")
    throw new Error(`get_investigation ${resp.status} ${body}`)
  }
  return await resp.json()
}

async function snapshot(stateDir, baseUrl, investigationId, watchToken, label) {
  try {
    const state = await fetchGetInvestigation(baseUrl, investigationId, watchToken)
    await writeStateAtomic(stateDir, state)
    return state
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err)
    process.stderr.write(`resolve-watch-investigation: ${label} get_investigation failed: ${msg}\n`)
    return undefined
  }
}

async function main() {
  const { investigationId, watchToken } = parseArgs(process.argv)
  const stateDir = fsSync.mkdtempSync(path.join(os.tmpdir(), "resolve-watch-inv-"))
  const baseUrl = resolveBaseUrl()

  const params = new URLSearchParams()
  params.set("watch_token", watchToken)
  const streamUrl = `${baseUrl}/api/resolve-mcp/v2/investigations/${encodeURIComponent(investigationId)}/stream?${params.toString()}`

  // Don't log the query string — it carries the watch token.
  process.stderr.write(
    `resolve-watch-investigation: streaming ${baseUrl}/api/resolve-mcp/v2/investigations/${encodeURIComponent(investigationId)}/stream\n`,
  )
  process.stderr.write(`state_dir=${stateDir}\n`)
  process.stderr.write(`resolve-watch-investigation: state at ${path.join(stateDir, "state.json")}\n`)

  // Seed snapshot — best-effort.
  await snapshot(stateDir, baseUrl, investigationId, watchToken, "initial")

  const abortCtl = new AbortController()
  const onSignal = () => abortCtl.abort()
  process.on("SIGTERM", onSignal)
  process.on("SIGINT", onSignal)
  process.on("SIGHUP", onSignal)

  // Periodic snapshot. Track the in-flight one so the final snapshot can wait
  // for it and so a slow fetch doesn't pile up overlapping ticks.
  let pendingPeriodic
  const snapshotTimer = setInterval(() => {
    if (abortCtl.signal.aborted || pendingPeriodic) return
    pendingPeriodic = snapshot(stateDir, baseUrl, investigationId, watchToken, "periodic").finally(() => {
      pendingPeriodic = undefined
    })
  }, SNAPSHOT_INTERVAL_MS)

  let exitCode = 0
  try {
    const resp = await fetch(streamUrl, {
      headers: { Accept: "text/event-stream" },
      signal: abortCtl.signal,
    })
    if (!resp.ok) {
      const body = await resp.text().catch(() => "")
      process.stderr.write(`resolve-watch-investigation: stream HTTP ${resp.status} ${body}\n`)
      exitCode = 1
    } else if (!resp.body) {
      process.stderr.write(`resolve-watch-investigation: stream response has no body\n`)
      exitCode = 1
    } else {
      const reader = resp.body.getReader()
      const decoder = new TextDecoder()
      while (!abortCtl.signal.aborted) {
        const { done, value } = await reader.read()
        if (done) break
        process.stdout.write(decoder.decode(value, { stream: true }))
      }
    }
  } catch (err) {
    if (!abortCtl.signal.aborted) {
      process.stderr.write(
        `resolve-watch-investigation: stream error: ${err instanceof Error ? err.message : String(err)}\n`,
      )
      exitCode = 1
    }
  } finally {
    clearInterval(snapshotTimer)
    process.off("SIGTERM", onSignal)
    process.off("SIGINT", onSignal)
    process.off("SIGHUP", onSignal)
  }

  // Let any in-flight periodic finish first so the final snapshot's write lands last.
  if (pendingPeriodic) await pendingPeriodic
  await snapshot(stateDir, baseUrl, investigationId, watchToken, "final")

  // Exit code reflects the streaming outcome only, not the investigation's conclusion.
  process.exit(exitCode)
}

main().catch(err => {
  process.stderr.write(`resolve-watch-investigation: fatal: ${err instanceof Error ? err.message : String(err)}\n`)
  process.exit(1)
})
