#!/usr/bin/env node
// Watcher CLI. Pipes Resolve's server-formatted text stream to stdout while
// bracketing it with two `get_chat` snapshots written to state.json (one at
// start, one when the stream closes). Host harness wakes the agent on
// process exit; the agent can `cat state.json` for the structured final
// state and tail stdout for the live transcript.
//
// The wire format is decided server-side — this script does no parsing.
// Adding tool calls, thinking blocks, new event kinds, etc. is a server
// concern; the watcher just streams bytes.
//
// Usage: resolve-watch <chat_id> --watch-token <token> [--investigation <id>] [--message-id <id>]
// Auth:  --watch-token, the short-lived chat-scoped token returned by `ask`
//        (no personal API key). Sent as the ?watch_token= query param.
// Files: <state-dir>/state.json (atomic; before and after snapshots)
//
// The Resolve base URL is read from config.json — the same host the
// MCP server connects to.

import fs from "node:fs/promises"
import fsSync from "node:fs"
import path from "node:path"
import os from "node:os"
import { fileURLToPath } from "node:url"

const PLUGIN_ROOT = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..")
const CONFIG_PATH = path.join(PLUGIN_ROOT, "config.json")

function usage() {
  process.stderr.write(
    "Usage: resolve-watch <chat_id> --watch-token <token> [--investigation <id>] [--message-id <id>]\n",
  )
  process.stderr.write("The watch token is returned by `ask` (no API key).\n")
  process.exit(2)
}

function parseArgs(argv) {
  const args = argv.slice(2)
  if (args.length === 0) usage()
  const chatId = args[0]
  if (!chatId || chatId.startsWith("--")) usage()
  let investigationId
  let messageId
  let watchToken
  for (let i = 1; i < args.length; i++) {
    const flag = args[i]
    if (flag === "--investigation") {
      const v = args[++i]
      if (!v) usage()
      investigationId = v
    } else if (flag === "--message-id") {
      const v = args[++i]
      if (!v) usage()
      messageId = v
    } else if (flag === "--watch-token") {
      const v = args[++i]
      if (!v) usage()
      watchToken = v
    } else {
      usage()
    }
  }
  if (!watchToken) usage()
  return { chatId, investigationId, messageId, watchToken }
}

function resolveBaseUrl() {
  const raw = fsSync.readFileSync(CONFIG_PATH, "utf8")
  const json = JSON.parse(raw)
  if (typeof json.baseUrl !== "string") {
    throw new Error(`resolve-watch: ${CONFIG_PATH} is missing a string "baseUrl" field`)
  }
  return json.baseUrl.replace(/\/+$/, "")
}

async function writeStateAtomic(stateDir, state) {
  await fs.mkdir(stateDir, { recursive: true })
  const tmpPath = path.join(stateDir, "state.json.tmp")
  const finalPath = path.join(stateDir, "state.json")
  await fs.writeFile(tmpPath, JSON.stringify(state, null, 2))
  await fs.rename(tmpPath, finalPath)
}

async function fetchGetChat(baseUrl, chatId, investigationId, watchToken) {
  const params = new URLSearchParams()
  params.set("watch_token", watchToken)
  if (investigationId) params.set("investigation_id", investigationId)
  const url = `${baseUrl}/api/resolve-mcp/v2/chats/${encodeURIComponent(chatId)}?${params.toString()}`
  const resp = await fetch(url)
  if (!resp.ok) {
    const body = await resp.text().catch(() => "")
    throw new Error(`get_chat ${resp.status} ${body}`)
  }
  return await resp.json()
}

async function main() {
  const { chatId, investigationId, messageId, watchToken } = parseArgs(process.argv)
  const stateDir = fsSync.mkdtempSync(path.join(os.tmpdir(), "resolve-watch-"))
  const baseUrl = resolveBaseUrl()

  const params = new URLSearchParams()
  params.set("watch_token", watchToken)
  if (investigationId) params.set("investigation_id", investigationId)
  if (messageId) params.set("messageId", messageId)
  const streamUrl = `${baseUrl}/api/resolve-mcp/v2/chats/${encodeURIComponent(chatId)}/stream?${params.toString()}`

  // Don't log the query string — it carries the watch token.
  process.stderr.write(
    `resolve-watch: streaming ${baseUrl}/api/resolve-mcp/v2/chats/${encodeURIComponent(chatId)}/stream\n`,
  )
  process.stderr.write(`state_dir=${stateDir}\n`)
  process.stderr.write(`resolve-watch: state at ${path.join(stateDir, "state.json")}\n`)

  // First snapshot — best-effort; if it fails the stream might still work.
  try {
    const seed = await fetchGetChat(baseUrl, chatId, investigationId, watchToken)
    await writeStateAtomic(stateDir, seed)
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err)
    process.stderr.write(`resolve-watch: initial get_chat failed: ${msg} (continuing)\n`)
  }

  const abortCtl = new AbortController()
  const onSignal = () => abortCtl.abort()
  process.on("SIGTERM", onSignal)
  process.on("SIGINT", onSignal)
  process.on("SIGHUP", onSignal)

  let exitCode = 0
  let streamErrored = false
  try {
    const resp = await fetch(streamUrl, {
      headers: { Accept: "text/event-stream" },
      signal: abortCtl.signal,
    })
    if (!resp.ok) {
      const body = await resp.text().catch(() => "")
      process.stderr.write(`resolve-watch: stream HTTP ${resp.status} ${body}\n`)
      streamErrored = true
      exitCode = 1
    } else if (!resp.body) {
      process.stderr.write(`resolve-watch: stream response has no body\n`)
      streamErrored = true
      exitCode = 1
    } else {
      const reader = resp.body.getReader()
      const decoder = new TextDecoder()
      while (!abortCtl.signal.aborted) {
        const { done, value } = await reader.read()
        if (done) break
        // Pipe bytes straight through. The server already filters out the
        // SSE-comment heartbeat lines visually (they start with `:` so they
        // render as a barely-noticeable comment for any consumer that cares).
        process.stdout.write(decoder.decode(value, { stream: true }))
      }
    }
  } catch (err) {
    if (!abortCtl.signal.aborted) {
      process.stderr.write(`resolve-watch: stream error: ${err instanceof Error ? err.message : String(err)}\n`)
      streamErrored = true
      exitCode = 1
    }
  } finally {
    process.off("SIGTERM", onSignal)
    process.off("SIGINT", onSignal)
    process.off("SIGHUP", onSignal)
  }

  // Final snapshot — overwrites the seed with the post-stream state.
  try {
    const final = await fetchGetChat(baseUrl, chatId, investigationId, watchToken)
    await writeStateAtomic(stateDir, final)
    if (!streamErrored && final.status === "errored") exitCode = 1
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err)
    process.stderr.write(`resolve-watch: final get_chat failed: ${msg}\n`)
    if (!streamErrored) exitCode = 1
  }

  process.exit(exitCode)
}

main().catch(err => {
  process.stderr.write(`resolve-watch: fatal: ${err instanceof Error ? err.message : String(err)}\n`)
  process.exit(1)
})
